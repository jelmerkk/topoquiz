{
  "name": "topoquiz",
  "version": "1.0.0",
  "description": "Een topografie-oefentool voor groep 5, gebaseerd op de Geobas-methode. Kinderen leren plaatsen en provincies via meerkeuze of zelf typen, met spaced repetition.",
  "main": "cities.js",
  "scripts": {
    "test": "npm run test:coverage && npx playwright test",
    "test:unit": "node test.mjs",
    "test:coverage": "c8 --include=cities.js --lines=100 --functions=100 --branches=50 --check-coverage node test.mjs",
    "test:e2e": "npx playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://codeberg.org/jelmerk/topoquiz.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://codeberg.org/jelmerk/topoquiz/issues"
  },
  "homepage": "https://codeberg.org/jelmerk/topoquiz#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "c8": "^10.1.3",
    "serve": "^14.2.6"
  }
}
